# MetaFeature-Orchestrator v2.0 Environment Configuration
# =========================================================

# Azure OpenAI Configuration (Recommended)
# -----------------------------------------
# Required for both Template Mode simulation and AI Agent Mode
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-api-key
OPENAI_API_VERSION=2024-02-15-preview
DEPLOYMENT_NAME=gpt-4o

# Standard OpenAI Configuration (Alternative)
# --------------------------------------------
# Comment out Azure settings above and uncomment below to use OpenAI directly
# OPENAI_API_KEY=your-api-key

# DALL-E 3 Image Generation (Optional)
# ------------------------------------
# Used for testing image-related AI features
# AZURE_DALLE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# AZURE_DALLE_API_KEY=your-api-key
# DALLE_API_VERSION=2024-04-01-preview
# DALLE_DEPLOYMENT_NAME=dall-e-3

# Notes:
# - AI Agent Mode requires Azure OpenAI + agent-framework package
# - Template Mode works without any API keys (deterministic)
# - Simulation & Evaluation require Azure OpenAI or OpenAI API